# Environment
NODE_ENV=production

# Frontend URL (for CORS and cookies)
FRONTEND_URL=https://PlantSheep.braavo.cloud

# Cookie Domain (for production cross-domain cookies)
COOKIE_DOMAIN=.braavo.cloud

# MongoDB Connection
MONGODB_URI=mongodb+srv://[user]:[pass]@[cluster].mongodb.net/?appName=plants

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_ACCESS_SECRET=your-secure-random-string-min-32-chars-change-this
JWT_REFRESH_SECRET=your-secure-random-string-min-32-chars-change-this

# JWT Expiration
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Server Port
PORT=3008

# OpenAI API Key
OPENAI_API_KEY=sk-proj-...
